# Step 1: Read input for the first set
m = int(input())
set_a = set(map(int, input().split()))

# Step 2: Read input for the second set
n = int(input())
set_b = set(map(int, input().split()))

# Step 3: Find the symmetric difference
# This can be done using the ^ operator or the symmetric_difference() method
sym_diff = set_a.symmetric_difference(set_b)

# Step 4: Sort the results and print each on a new line
for value in sorted(sym_diff):
    print(value)
